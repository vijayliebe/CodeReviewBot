# CodeReviewBot Environment Configuration
# Duplicate this file as '.env' and populate with your keys.

# Gemini API Key (Required for LLM analysis)
GOOGLE_API_KEY=your_gemini_api_key_here

# GitHub Personal Access Token (Optional, required for reviewing remote Pull Requests)
GITHUB_TOKEN=your_github_pat_here

# MCP configuration (Optional)
GITHUB_REPOSITORY=owner/repo
